---
import Logo from './icons/Logo.astro';
import IconPhone from './icons/IconPhone.astro';
import IconEmail from './icons/IconEmail.astro';
import IconLocation from './icons/IconLocation.astro';
import IconFacebook from './icons/IconFacebook.astro';
---

<footer class="footer" id="footer">
  <div class="container">
    <div class="footer-grid">
      <div>
        <div class="footer-logo">
          <Logo />
          Steve Thompson Limited
        </div>
        <p class="footer-description">Your trusted partner in forestry solutions across New Zealand. Professional equipment, expert services, and a team that understands the demands of the landscape.</p>
      </div>

      <div>
        <h4>Quick Links</h4>
        <div class="footer-links">
          <a href="/">Home</a>
          <a href="/services/earthworks">Earthworks</a>
          <a href="/services/forestry">Forestry</a>
          <a href="/services/trucking">Trucking</a>
          <a href="/services/firewood">Firewood</a>
          <a href="/fleet">Fleet</a>
          <a href="/contact">Contact</a>
        </div>
      </div>

      <div>
        <h4>Contact</h4>
        <div class="footer-contact-item">
          <IconPhone />
          <a href="tel:0273674569">027 367 4569</a>
        </div>
        <div class="footer-contact-item">
          <IconEmail />
          <a href="mailto:steve@stlservices.co.nz">steve@stlservices.co.nz</a>
        </div>
        <div class="footer-contact-item">
          <IconLocation />
          <span>Nelson, New Zealand</span>
        </div>
      </div>
    </div>

    <div class="footer-bottom">
      <span>&copy; 2026 Steve Thompson Limited. All rights reserved.</span>
      <div class="footer-social">
        <a href="#" aria-label="Facebook">
          <IconFacebook />
        </a>
      </div>
    </div>
  </div>
</footer>
